# ─────────────────────────────────────────────────────────────────────────────
# Contexta — environment template. Copy to .env and fill in.
# Validated at boot by @contexta/config (packages/config/src/env.ts).
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# API server (apps/api)
API_PORT=8080
API_HOST=0.0.0.0
# Comma-separated allowlist for CORS (web origin).
CORS_ORIGINS=http://localhost:3000
# Secret used to sign/verify internal worker->api calls. Generate a random 32+ char value.
INTERNAL_API_SECRET=change-me-internal-secret-please-rotate

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key — BACKEND ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Stellar / Soroban ───────────────────────────────────────────────────────
# network: testnet | mainnet | local
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Secret seed (S...) for the platform service account used to submit txns.
# In production this should be a sponsored / multisig / smart-wallet key, never a raw seed.
STELLAR_SERVICE_SECRET=
# Deployed contract IDs (C...) — fill after `stellar contract deploy`.
TREASURY_CONTRACT_ID=
PAYROLL_CONTRACT_ID=
# USDC SAC contract id on the chosen network (testnet default left blank — see contracts/README).
USDC_CONTRACT_ID=

# ── DeFindex ────────────────────────────────────────────────────────────────
DEFINDEX_API_URL=https://api.defindex.io
DEFINDEX_API_KEY=
# Optional: pin a default factory / vault for demos.
DEFINDEX_FACTORY_CONTRACT_ID=

# ── Blend Protocol (testnet defaults — verify against blend docs) ───────────
BLEND_POOL_CONTRACT_ID=
BLEND_BACKSTOP_CONTRACT_ID=
BLEND_ORACLE_CONTRACT_ID=

# ── Oracles / FX ────────────────────────────────────────────────────────────
# When unset the platform uses the deterministic mock FX provider.
FX_PROVIDER=mock
FX_API_URL=
FX_API_KEY=

# ── Worker / Agent ──────────────────────────────────────────────────────────
# Poll interval in seconds for the agent rebalance loop.
AGENT_POLL_INTERVAL_SECONDS=300
# When true the agent only proposes (never auto-executes) treasury moves.
AGENT_DRY_RUN=true
API_BASE_URL=http://localhost:8080

# ── Legal Context Protocol (LCP) ────────────────────────────────────────────
# Base domain used to render per-tenant .well-known/legal-context.json URLs.
LCP_PLATFORM_DOMAIN=contexta.app
